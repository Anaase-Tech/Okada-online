# Okada Online — Environment Variables
# Copy to .env.local and fill in values
# NEVER commit .env.local to git

# Backend API
REACT_APP_API_URL=https://us-central1-okada-online-ghana.cloudfunctions.net/api

# Firebase (Firebase Console → Project Settings → Your Apps → Web)
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=okada-online-ghana.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=okada-online-ghana
REACT_APP_FIREBASE_STORAGE_BUCKET=okada-online-ghana.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id

# Google Maps (Google Cloud Console → APIs → Maps JavaScript API)
REACT_APP_GOOGLE_MAPS_KEY=your_google_maps_api_key

# App Config
REACT_APP_ENV=production
