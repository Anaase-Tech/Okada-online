      .where('userId','==', userId)
      .orderBy('createdAt','desc').limit(20).get();
    return ok(res, { rides: snap.docs.map(d => ({ id: d.id, ...d.data() })) });
  } catch (e) {
    return fail(res, 500, e.message);
  }
});

